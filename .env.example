# Bu dosyayi .env olarak kopyalayip degerleri doldurun. .env asla commit edilmez.

# --- Backend genel ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://proby:proby@localhost:5432/proby

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=problem_records

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Google Gemini (LLM + embedding) ---
# https://aistudio.google.com/apikey adresinden alinabilir
# NOT: gemini-1.5-flash ve text-embedding-004 kullanimdan kaldirildi/kaldirilma
# surecinde (bkz. ai.google.dev/gemini-api/docs/deprecations). Gercek entegrasyon
# oncesi guncel model adlarini (orn. gemini-3.5-flash, gemini-embedding-001) kontrol edip
# burayi guncelleyin; embedding modeli degisirse EMBEDDING_DIMENSION'i da guncelleyin.
GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSION=768

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
